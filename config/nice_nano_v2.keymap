#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>

/ {
    chosen {
        zmk,display = &oled;
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer: layer_0 {
            label = "BASE";
            bindings = <
                &kp F7     &kp F3     &kp F1     &kp D      // 0-3
                &kp S      &kp W      &kp A      &none      // 4-7 (功能键1)
                &none      &kp I      &kp O      &kp P      // 8-11 (功能键2)
                &kp H      &kp J      &kp K      &kp L      // 12-15
            >;
        };
    };
};