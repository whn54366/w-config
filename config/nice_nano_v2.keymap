#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    // 严格参考ZMK官方kscan-gpio-direct驱动示例的写法
    kscan {
        compatible = "zmk,kscan-gpio-direct";
        status = "okay";

        // 16个按键，顺序和keymap里的bindings一一对应
        key_00 { gpios = <&gpio1 6  (GPIO_ACTIVE_LOW)>; }; // W
        key_01 { gpios = <&gpio1 1  (GPIO_ACTIVE_LOW)>; }; // A
        key_02 { gpios = <&gpio1 4  (GPIO_ACTIVE_LOW)>; }; // S
        key_03 { gpios = <&gpio0 11 (GPIO_ACTIVE_LOW)>; }; // D
        key_04 { gpios = <&gpio0 9  (GPIO_ACTIVE_LOW)>; }; // I
        key_05 { gpios = <&gpio1 15 (GPIO_ACTIVE_LOW)>; }; // J
        key_06 { gpios = <&gpio0 2  (GPIO_ACTIVE_LOW)>; }; // K
        key_07 { gpios = <&gpio0 29 (GPIO_ACTIVE_LOW)>; }; // L
        key_08 { gpios = <&gpio1 13 (GPIO_ACTIVE_LOW)>; }; // H
        key_09 { gpios = <&gpio0 10 (GPIO_ACTIVE_LOW)>; }; // O
        key_10 { gpios = <&gpio1 11 (GPIO_ACTIVE_LOW)>; }; // P
        key_11 { gpios = <&gpio1 0  (GPIO_ACTIVE_LOW)>; }; // F1
        key_12 { gpios = <&gpio0 24 (GPIO_ACTIVE_LOW)>; }; // F3
        key_13 { gpios = <&gpio0 22 (GPIO_ACTIVE_LOW)>; }; // F7
        key_14 { gpios = <&gpio1 2  (GPIO_ACTIVE_LOW)>; }; // FN1 层切换1
        key_15 { gpios = <&gpio1 7  (GPIO_ACTIVE_LOW)>; }; // FN2 层切换2
    };

    // 严格遵循ZMK官方keymap规范，每层bindings数量完全一致（16个）
    keymap {
        compatible = "zmk,keymap";

        // 层0：默认层（16个绑定，和按键一一对应）
        default_layer {
            bindings = <
                &kp W    &kp A    &kp S    &kp D
                &kp I    &kp J    &kp K    &kp L
                &kp H    &kp O    &kp P
                &kp F1   &kp F3   &kp F7
                &mo 1    &mo 2
            >;
        };

        // 层1：功能层（长按FN1触发，16个绑定，数量完全匹配）
        fn_layer1 {
            bindings = <
                &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_CLR  &kp SLEEP
                &kp RESET     &kp F1         &none        &none
                &none         &none          &none
                &none         &none          &none
                &none         &none
            >;
        };

        // 层2：备用层（长按FN2触发，16个绑定，数量完全匹配）
        fn_layer2 {
            bindings = <
                &none  &none  &none  &none
                &none  &none  &none  &none
                &none  &none  &none
                &none  &none  &none
                &none  &none
            >;
        };
    };
};