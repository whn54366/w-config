#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // 顺序 = overlay 里 input-gpios 的顺序
            bindings = <
    &kp F7   &kp F3   &kp F1   &kp D
    &kp S    &kp W    &kp A    &none
    &none    &kp I    &kp O    &kp P
    &kp H    &kp J    &kp K    &kp L
            >;
        };
    };
};